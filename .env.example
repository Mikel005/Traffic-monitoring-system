# ── Django ────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (PostgreSQL + TimescaleDB) ───────────────────
DATABASE_URL=postgres://traffic_user:traffic_pass@localhost:5432/traffic_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=traffic-raw
KAFKA_TOPIC_DETECTIONS=camera-detections

# ── External APIs ─────────────────────────────────────────
# Leave blank to use mock/simulated data
TOMTOM_API_KEY=
OPENWEATHER_API_KEY=

# ── ML Models ─────────────────────────────────────────────
LSTM_MODEL_PATH=ml/saved_models/lstm_best.onnx
XGB_MODEL_PATH=ml/saved_models/xgb_classifier.pkl
YOLO_WEIGHTS_PATH=vision/weights/yolov8s.pt

# ── App behaviour ─────────────────────────────────────────
USE_MOCK_DATA=True
MOCK_LOCATIONS=5
